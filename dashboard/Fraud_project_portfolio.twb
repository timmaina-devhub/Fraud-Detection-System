            <column caption='fraud_labels_true' datatype='integer' datatype-customized='true' name='[Calculation_0524798975803392]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(IF [is_fraud] == 1 then [is_fraud] END)' />
            </column>
            <column caption='month_chosen_show_dates(db4_training)' datatype='date' name='[Calculation_0524798985912323]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF ([Parameters].[Parameter 4]) == MONTH([timestamp]) THEN DATE([timestamp]) END' />
            </column>
            <column caption='chosen_month_show_days(db4_training)' datatype='integer' name='[Calculation_0524798990921734]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 4]==MONTH([timestamp]) then DATEPART(&apos;day&apos;, [Calculation_0524798985912323]) END' />
