              <calculation class='tableau' formula='INT(IF [is_fraud] == 1 then [is_fraud] END)' />
            </column>
            <column caption='month_chosen_show_dates(db4_training)' datatype='date' name='[Calculation_0524798985912323]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF ([Parameters].[Parameter 4]) == MONTH([timestamp]) THEN DATE([timestamp]) END' />
            </column>
            <column caption='chosen_month_show_days(db4_training)' datatype='integer' name='[Calculation_0524798990921734]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 4]==MONTH([timestamp]) then DATEPART(&apos;day&apos;, [Calculation_0524798985912323]) END' />
            </column>
            <column caption='from_chosen_date_show_hours(db4_training)' datatype='integer' name='[Calculation_0524798991777799]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='if [Parameters].[Parameter 1]==DATEPART(&apos;day&apos;, [Calculation_0524798985912323]) THEN DATEPART(&apos;hour&apos;, [timestamp_min]) END' />
            </column>
            <column caption='from_chosen_hour_of_chosen_date_show_minutes(db4_training)' datatype='integer' name='[Calculation_0524798992646152]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 5] == DATEPART(&apos;hour&apos;,[timestamp_min]) THEN DATEPART(&apos;minute&apos;, [timestamp_min]) END' />
            </column>
            <column caption='Fraud_rate_transactions_min' datatype='real' name='[Calculation_0524798995738633]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNT([Calculation_0524798975803392]) / SUM([transactions_min])' />
