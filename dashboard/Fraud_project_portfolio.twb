    <worksheet name='transaction_per_device_fraud_rate'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#919191' fontname='Microsoft Sans Serif' fontsize='8'>Fraud Rate of DeviceIDs (&gt;=10 transactions)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='data_before_training' name='federated.1azz1hy163g3n112zwsuh0prfwaz' />
          </datasources>
          <datasource-dependencies datasource='federated.1azz1hy163g3n112zwsuh0prfwaz'>
            <column caption='fraud_labels_true' datatype='integer' datatype-customized='true' name='[Calculation_0524798975803392]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(IF [is_fraud] == 1 then [is_fraud] END)' />
            </column>
            <column caption='true fraud_rate_devices' datatype='real' name='[Calculation_0524798976434177]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_0524798975803392]) / SUM([transactions_per_device])' />
            </column>
            <column-instance column='[Calculation_0524798975803392]' derivation='Count' name='[cnt:Calculation_0524798975803392:qk]' pivot='key' type='quantitative' />
            <column caption='Device Id' datatype='string' name='[device_id]' role='dimension' type='nominal' />
            <column caption='Is Fraud' datatype='real' name='[is_fraud]' role='measure' type='quantitative' />
            <column-instance column='[device_id]' derivation='None' name='[none:device_id:nk]' pivot='key' type='nominal' />
