      <column aggregation='CountD' caption='non_fraud_transactions' datatype='string' default-role='measure' default-type='quantitative' name='[Calculation_0208139685945344]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [is_fraud]==0 THEN [transaction_id] END' />
      </column>
      <column caption='non_fraud_transaction_amount(db4_training)' datatype='real' name='[Calculation_0208139686887425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_fraud] == 0 THEN [amount_usd] END' />
      </column>
      <column caption='fraud_transaction_amount(db4_training)' datatype='real' name='[Calculation_0208139687378946]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [is_fraud] == 1 THEN [amount_usd] END' />
      </column>
      <column caption='Recall_score_model(db4_training)' datatype='real' name='[Calculation_0208139695292419]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0.8915' />
      </column>
      <column caption='Estimated_loss_prevented(db4_training)' datatype='real' name='[Calculation_0208139695685636]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0208139695292419] * [Calculation_0208139687378946]' />
      </column>
      <column caption='fraud_labels_true' datatype='integer' datatype-customized='true' name='[Calculation_0524798975803392]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(IF [is_fraud] == 1 then [is_fraud] END)' />
      </column>
      <column caption='true fraud_rate_devices' datatype='real' name='[Calculation_0524798976434177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0524798975803392]) / SUM([transactions_per_device])' />
      </column>
      <column caption='fraud_rate_ip&apos;s' datatype='real' name='[Calculation_0524798981033986]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Calculation_0524798975803392]) / SUM([ip_transactions])' />
      </column>
      <column caption='month_chosen_show_dates(db4_training)' datatype='date' name='[Calculation_0524798985912323]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ([Parameters].[Parameter 4]) == MONTH([timestamp]) THEN DATE([timestamp]) END' />
      </column>
      <column caption='months(db4_training)' datatype='integer' name='[Calculation_0524798987653124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([timestamp])' />
      </column>
      <column caption='chosen_month_show_days(db4_training)' datatype='integer' name='[Calculation_0524798990921734]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 4]==MONTH([timestamp]) then DATEPART(&apos;day&apos;, [Calculation_0524798985912323]) END' />
      </column>
      <column caption='from_chosen_date_show_hours(db4_training)' datatype='integer' name='[Calculation_0524798991777799]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [Parameters].[Parameter 1]==DATEPART(&apos;day&apos;, [Calculation_0524798985912323]) THEN DATEPART(&apos;hour&apos;, [timestamp_min]) END' />
      </column>
      <column caption='from_chosen_hour_of_chosen_date_show_minutes(db4_training)' datatype='integer' name='[Calculation_0524798992646152]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 5] == DATEPART(&apos;hour&apos;,[timestamp_min]) THEN DATEPART(&apos;minute&apos;, [timestamp_min]) END' />
      </column>
      <column caption='Fraud_rate_transactions_min' datatype='real' name='[Calculation_0524798995738633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Calculation_0524798975803392]) / SUM([transactions_min])' />
      </column>
